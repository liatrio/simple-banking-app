<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.smartbank.controller.AccountListController" 
      spacing="8" alignment="TOP_CENTER" VBox.vgrow="ALWAYS" 
      HBox.hgrow="ALWAYS" fillWidth="true">
    
    <padding>
        <Insets top="10" right="10" bottom="10" left="10"/>
    </padding>
    
    <Label text="Account List" styleClass="heading" />
    
    <TableView fx:id="accountTable" VBox.vgrow="ALWAYS" HBox.hgrow="ALWAYS">
        <columns>
            <TableColumn text="Account Number" fx:id="colAccountNumber" prefWidth="150" />
            <TableColumn text="Holder" fx:id="colHolder" prefWidth="150" />
            <TableColumn text="Type" fx:id="colType" prefWidth="120" />
            <TableColumn text="Balance" fx:id="colBalance" prefWidth="120" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
    </TableView>
</VBox>
