<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="10" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.smartbank.controller.BudgetController">
    <padding>
        <Insets top="15" right="15" bottom="15" left="15"/>
    </padding>
    
    <!-- Header -->
    <HBox alignment="CENTER">
        <Label text="Budget Management" styleClass="heading">
            <font>
                <Font name="System Bold" size="18.0"/>
            </font>
        </Label>
    </HBox>
    
    <!-- Account and Period Selection -->
    <HBox spacing="10" alignment="CENTER">
        <Label text="Account:" />
        <ComboBox fx:id="cmbAccount" prefWidth="200" promptText="Select Account" />
        <Label text="Budget Period:" />
        <ComboBox fx:id="cmbPeriod" prefWidth="100" />
        <Label text="Current Period:" />
        <Label fx:id="lblPeriod" text="[Current Period]" style="-fx-font-weight: bold;" />
        <Label text="(" />
        <Label fx:id="lblDaysRemaining" text="XX days remaining" />
        <Label text=")" />
        <Button text="Refresh" onAction="#handleRefresh" />
    </HBox>
    
    <!-- Main Content -->
    <SplitPane dividerPositions="0.6" VBox.vgrow="ALWAYS">
        <!-- Budget Table -->
        <VBox spacing="5">
            <TableView fx:id="tblBudget" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colCategory" text="Category" prefWidth="100"/>
                    <TableColumn fx:id="colBudget" text="Budget" prefWidth="80"/>
                    <TableColumn fx:id="colSpent" text="Spent" prefWidth="80"/>
                    <TableColumn fx:id="colRemaining" text="Remaining" prefWidth="80"/>
                    <TableColumn fx:id="colPercentage" text="Percentage Used" prefWidth="100"/>
                    <TableColumn fx:id="colStatus" text="Status" prefWidth="80"/>
                    <TableColumn fx:id="colDailyAllowance" text="Daily Allowance" prefWidth="120"/>
                </columns>
                <placeholder>
                    <Label text="No budget data available"/>
                </placeholder>
            </TableView>
        </VBox>
        
        <!-- Budget Setting and Charts -->
        <VBox spacing="10">
            <!-- Budget Setting -->
            <TitledPane text="Set Category Budget" expanded="true">
                <GridPane hgap="10" vgap="10">
                    <padding>
                        <Insets top="5" right="5" bottom="5" left="5"/>
                    </padding>
                    
                    <!-- Category -->
                    <Label text="Category:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <ComboBox fx:id="cmbCategory" GridPane.rowIndex="0" GridPane.columnIndex="1" 
                              GridPane.hgrow="ALWAYS" maxWidth="Infinity"/>
                    
                    <!-- Budget Amount -->
                    <Label text="Budget Amount:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtBudgetAmount" GridPane.rowIndex="1" GridPane.columnIndex="1" 
                               GridPane.hgrow="ALWAYS" promptText="0.00"/>
                    
                    <!-- Budget Buttons -->
                    <HBox spacing="10" GridPane.rowIndex="2" GridPane.columnIndex="1" GridPane.halignment="RIGHT" alignment="CENTER_RIGHT">
                        <Button fx:id="btnCreateDefaultBudgets" text="Create Default Budgets" onAction="#handleCreateDefaultBudgets" />
                        <Button fx:id="btnSetBudget" text="Set Budget" onAction="#handleSetBudget" />
                    </HBox>
                    
                    <columnConstraints>
                        <ColumnConstraints percentWidth="30"/>
                        <ColumnConstraints percentWidth="70"/>
                    </columnConstraints>
                </GridPane>
            </TitledPane>
            
            <!-- Charts -->
            <TabPane tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
                <Tab text="Spending Distribution">
                    <PieChart fx:id="chartSpending" title="Spending by Category" />
                </Tab>
                <Tab text="Budget vs Actual">
                    <BarChart fx:id="chartBudgetVsActual" title="Budget vs Actual Spending">
                        <xAxis>
                            <CategoryAxis label="Category" />
                        </xAxis>
                        <yAxis>
                            <NumberAxis label="Amount ($)" />
                        </yAxis>
                    </BarChart>
                </Tab>
            </TabPane>
            
            <!-- Report Generation -->
            <HBox spacing="10" alignment="CENTER">
                <Label text="Generate Report:" />
                <ComboBox fx:id="cmbReportFormat" prefWidth="100" />
                <Button fx:id="btnGenerateReport" text="Generate Report" onAction="#handleGenerateReport" />
            </HBox>
            
            <!-- Test Data Generation -->
            <HBox spacing="10" alignment="CENTER">
                <Label text="Test Data:" />
                <Button fx:id="btnGenerateSampleData" text="Generate Sample Transactions" onAction="#handleGenerateSampleData" />
                <Button fx:id="btnGenerateBudgetData" text="Generate Budget Test Data" onAction="#handleGenerateBudgetData" />
            </HBox>
            
            <!-- Status -->
            <Label fx:id="lblStatus" wrapText="true"/>
        </VBox>
    </SplitPane>
</VBox>