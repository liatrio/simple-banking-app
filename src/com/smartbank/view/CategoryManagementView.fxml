<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="10" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.smartbank.controller.CategoryManagementController">
    <padding>
        <Insets top="15" right="15" bottom="15" left="15"/>
    </padding>
    
    <!-- Header -->
    <HBox alignment="CENTER">
        <Label text="Category Management" styleClass="heading">
            <font>
                <Font name="System Bold" size="18.0"/>
            </font>
        </Label>
    </HBox>
    
    <!-- Main Content -->
    <SplitPane dividerPositions="0.6" VBox.vgrow="ALWAYS">
        <!-- Category Table -->
        <VBox spacing="5">
            <TableView fx:id="tblCategories" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colCategoryId" text="ID" prefWidth="50"/>
                    <TableColumn fx:id="colName" text="Name" prefWidth="100"/>
                    <TableColumn fx:id="colDescription" text="Description" prefWidth="150"/>
                    <TableColumn fx:id="colParent" text="Parent" prefWidth="100"/>
                    <TableColumn fx:id="colColor" text="Color" prefWidth="80"/>
                    <TableColumn fx:id="colKeywords" text="Keywords" prefWidth="150"/>
                    <TableColumn fx:id="colBudget" text="Budget" prefWidth="80"/>
                </columns>
                <placeholder>
                    <Label text="No categories available"/>
                </placeholder>
            </TableView>
            
            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Button text="Refresh" onAction="#handleRefresh"/>
            </HBox>
        </VBox>
        
        <!-- Category Form -->
        <VBox spacing="10">
            <GridPane hgap="10" vgap="10">
                <padding>
                    <Insets top="5" right="5" bottom="5" left="5"/>
                </padding>
                
                <!-- Name -->
                <Label text="Name:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <TextField fx:id="txtName" GridPane.rowIndex="0" GridPane.columnIndex="1" 
                           GridPane.hgrow="ALWAYS"/>
                
                <!-- Description -->
                <Label text="Description:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <TextField fx:id="txtDescription" GridPane.rowIndex="1" GridPane.columnIndex="1" 
                           GridPane.hgrow="ALWAYS"/>
                
                <!-- Parent Category -->
                <Label text="Parent Category:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <ComboBox fx:id="cmbParent" GridPane.rowIndex="2" GridPane.columnIndex="1" 
                          GridPane.hgrow="ALWAYS" maxWidth="Infinity"/>
                
                <!-- Color -->
                <Label text="Color:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                <ColorPicker fx:id="colorPicker" GridPane.rowIndex="3" GridPane.columnIndex="1" 
                             GridPane.hgrow="ALWAYS" maxWidth="Infinity"/>
                
                <!-- Keywords -->
                <Label text="Keywords:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                <TextField fx:id="txtKeywords" GridPane.rowIndex="4" GridPane.columnIndex="1" 
                           GridPane.hgrow="ALWAYS" promptText="Comma-separated keywords"/>
                
                <!-- Budget -->
                <Label text="Budget Amount:" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                <TextField fx:id="txtBudget" GridPane.rowIndex="5" GridPane.columnIndex="1" 
                           GridPane.hgrow="ALWAYS" promptText="0.00"/>
                
                <!-- System Category -->
                <Label text="System Category:" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
                <CheckBox fx:id="chkSystem" GridPane.rowIndex="6" GridPane.columnIndex="1"/>
                
                <columnConstraints>
                    <ColumnConstraints percentWidth="30"/>
                    <ColumnConstraints percentWidth="70"/>
                </columnConstraints>
            </GridPane>
            
            <!-- Buttons -->
            <HBox spacing="10" alignment="CENTER">
                <Button fx:id="btnAdd" text="Add Category" onAction="#handleAddCategory" defaultButton="true"/>
                <Button fx:id="btnUpdate" text="Update" onAction="#handleUpdateCategory"/>
                <Button fx:id="btnDelete" text="Delete" onAction="#handleDeleteCategory"/>
                <Button fx:id="btnClear" text="Clear" onAction="#handleClearForm"/>
            </HBox>
            
            <!-- Status -->
            <Label fx:id="lblStatus" wrapText="true"/>
            
            <VBox.margin>
                <Insets top="10"/>
            </VBox.margin>
        </VBox>
    </SplitPane>
    
    <!-- Help Text -->
    <TitledPane text="Help" expanded="false">
        <VBox spacing="5">
            <Label text="• Keywords are used for automatic categorization" wrapText="true"/>
            <Label text="• Budget Amount is used for budget vs. actual spending reports" wrapText="true"/>
            <Label text="• System categories cannot be deleted" wrapText="true"/>
            <Label text="• Color is used in reports and charts" wrapText="true"/>
        </VBox>
    </TitledPane>
</VBox>