<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.smartbank.controller.ChangePasswordController" 
      spacing="15" styleClass="content-panel">
    
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>
    
    <Label text="Change Password" styleClass="page-title"/>
    
    <GridPane hgap="15" vgap="10">
        <padding>
            <Insets top="10" right="10" bottom="10" left="10"/>
        </padding>
        
        <!-- Username Row -->
        <Label text="Username:" GridPane.rowIndex="0" GridPane.columnIndex="0" 
               styleClass="form-label"/>
        <Label fx:id="lblUsername" GridPane.rowIndex="0" GridPane.columnIndex="1" 
               styleClass="profile-value"/>
        
        <!-- Current Password Row -->
        <Label text="Current Password:" GridPane.rowIndex="1" GridPane.columnIndex="0" 
               styleClass="form-label"/>
        <PasswordField fx:id="txtCurrentPassword" GridPane.rowIndex="1" GridPane.columnIndex="1" 
                      promptText="Enter your current password"/>
        
        <!-- New Password Row -->
        <Label text="New Password:" GridPane.rowIndex="2" GridPane.columnIndex="0" 
               styleClass="form-label"/>
        <PasswordField fx:id="txtNewPassword" GridPane.rowIndex="2" GridPane.columnIndex="1" 
                      promptText="Enter new password"/>
        
        <!-- Confirm Password Row -->
        <Label text="Confirm Password:" GridPane.rowIndex="3" GridPane.columnIndex="0" 
               styleClass="form-label"/>
        <PasswordField fx:id="txtConfirmPassword" GridPane.rowIndex="3" GridPane.columnIndex="1" 
                      promptText="Confirm new password"/>
        
        <columnConstraints>
            <ColumnConstraints prefWidth="150" minWidth="150"/>
            <ColumnConstraints hgrow="ALWAYS"/>
        </columnConstraints>
    </GridPane>
    
    <!-- Password Requirements -->
    <VBox styleClass="requirements-box" spacing="5">
        <Label text="Password Requirements:" styleClass="requirements-title"/>
        <Label text="• At least 8 characters long" styleClass="requirement-item"/>
        <Label text="• At least one uppercase letter" styleClass="requirement-item"/>
        <Label text="• At least one lowercase letter" styleClass="requirement-item"/>
        <Label text="• At least one number" styleClass="requirement-item"/>
    </VBox>
    
    <!-- Action Buttons -->
    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Cancel" onAction="#handleCancel" styleClass="btn-secondary"/>
        <Button fx:id="btnSave" text="Change Password" onAction="#handleSave" 
                styleClass="btn-primary"/>
    </HBox>
    
    <!-- Status Message -->
    <Label fx:id="lblStatus" styleClass="status-message"/>
    
</VBox>