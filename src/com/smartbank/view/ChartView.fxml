<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.smartbank.controller.ChartController"
      spacing="10" styleClass="content-pane">
    
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>
    
    <Label text="Transaction Visualization" styleClass="header-label"/>
    
    <HBox spacing="15" alignment="CENTER_LEFT">
        <Label text="Account:" />
        <ComboBox fx:id="accountComboBox" prefWidth="250" />
    </HBox>
    
    <GridPane hgap="15" vgap="10">
        <columnConstraints>
            <ColumnConstraints hgrow="SOMETIMES" minWidth="150" prefWidth="150" />
            <ColumnConstraints hgrow="SOMETIMES" minWidth="150" prefWidth="150" />
            <ColumnConstraints hgrow="SOMETIMES" minWidth="150" prefWidth="150" />
            <ColumnConstraints hgrow="SOMETIMES" minWidth="150" prefWidth="150" />
        </columnConstraints>
        
        <Label text="Chart Type:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
        <ComboBox fx:id="chartTypeComboBox" prefWidth="150" 
                  GridPane.columnIndex="1" GridPane.rowIndex="0" />
        
        <Label text="Period Type:" GridPane.columnIndex="2" GridPane.rowIndex="0" />
        <ComboBox fx:id="periodTypeComboBox" prefWidth="150" 
                  GridPane.columnIndex="3" GridPane.rowIndex="0" />
        
        <Label text="Start Date:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
        <DatePicker fx:id="startDatePicker" prefWidth="150" 
                    GridPane.columnIndex="1" GridPane.rowIndex="1" />
        
        <Label text="End Date:" GridPane.columnIndex="2" GridPane.rowIndex="1" />
        <DatePicker fx:id="endDatePicker" prefWidth="150" 
                    GridPane.columnIndex="3" GridPane.rowIndex="1" />
    </GridPane>
    
    <HBox spacing="10">
        <Button fx:id="generateButton" text="Generate Chart" styleClass="action-button" />
        <Button fx:id="exportButton" text="Export Chart" styleClass="action-button" />
        <Button fx:id="refreshButton" text="Refresh" styleClass="action-button" />
    </HBox>
    
    <StackPane fx:id="chartContainer" VBox.vgrow="ALWAYS" styleClass="chart-container"
               minHeight="400" prefHeight="400" />
    
    <VBox fx:id="optionsContainer" spacing="5" />
    
    <HBox alignment="CENTER_LEFT">
        <Label fx:id="statusLabel" styleClass="status-label" />
    </HBox>
    
</VBox>