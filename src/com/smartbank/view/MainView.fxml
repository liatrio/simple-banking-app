<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.smartbank.controller.MainController">
   <top>
      <VBox alignment="CENTER" spacing="10.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
         <children>
            <Label text="SmartBank Banking System" textAlignment="CENTER">
               <font>
                  <Font name="System Bold" size="24.0" />
               </font>
            </Label>
            <Separator />
         </children>
      </VBox>
   </top>
   <left>
      <VBox prefWidth="200.0" spacing="10.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
         <children>
            <Label text="Account Operations" textAlignment="CENTER">
               <font>
                  <Font name="System Bold" size="14.0" />
               </font>
            </Label>
            <Button fx:id="newAccountButton" maxWidth="Infinity" mnemonicParsing="false" onAction="#handleNewAccount" text="New Account" />
            <Button fx:id="depositButton" maxWidth="Infinity" mnemonicParsing="false" onAction="#handleDeposit" text="Deposit" />
            <Button fx:id="withdrawButton" maxWidth="Infinity" mnemonicParsing="false" onAction="#handleWithdraw" text="Withdraw" />
            <Separator />
            <Label text="View Options" textAlignment="CENTER">
               <font>
                  <Font name="System Bold" size="14.0" />
               </font>
            </Label>
            <Button fx:id="accountDetailsButton" maxWidth="Infinity" mnemonicParsing="false" onAction="#handleViewAccountDetails" text="Account Details" />
            <Button fx:id="transactionHistoryButton" maxWidth="Infinity" mnemonicParsing="false" onAction="#handleViewTransactionHistory" text="Transaction History" />
         </children>
      </VBox>
   </left>
   <center>
      <TabPane prefHeight="200.0" prefWidth="200.0" tabClosingPolicy="UNAVAILABLE" BorderPane.alignment="CENTER">
        <tabs>
          <Tab text="Accounts">
               <content>
                  <VBox spacing="10.0">
                     <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                     </padding>
                     <children>
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                           <children>
                              <Label text="Account List" />
                              <Region HBox.hgrow="ALWAYS" />
                              <Button fx:id="refreshAccountsButton" mnemonicParsing="false" onAction="#handleRefreshAccounts" text="Refresh" />
                           </children>
                        </HBox>
                        <TableView fx:id="accountsTableView" VBox.vgrow="ALWAYS">
                          <columns>
                            <TableColumn fx:id="accountNumberColumn" prefWidth="100.0" text="Account #" />
                            <TableColumn fx:id="holderNameColumn" prefWidth="150.0" text="Holder Name" />
                            <TableColumn fx:id="accountTypeColumn" prefWidth="100.0" text="Type" />
                            <TableColumn fx:id="balanceColumn" prefWidth="100.0" text="Balance" />
                          </columns>
                        </TableView>
                     </children>
                  </VBox>
               </content>
          </Tab>
          <Tab text="Transaction History">
               <content>
                  <VBox spacing="10.0">
                     <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                     </padding>
                     <children>
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                           <children>
                              <Label text="Selected Account:" />
                              <ComboBox fx:id="accountSelector" prefWidth="150.0" promptText="Select Account" />
                              <Region HBox.hgrow="ALWAYS" />
                              <Button fx:id="refreshTransactionsButton" mnemonicParsing="false" onAction="#handleRefreshTransactions" text="Refresh" />
                           </children>
                        </HBox>
                        <TableView fx:id="transactionsTableView" VBox.vgrow="ALWAYS">
                          <columns>
                            <TableColumn fx:id="transactionDateColumn" prefWidth="150.0" text="Date" />
                            <TableColumn fx:id="transactionTypeColumn" prefWidth="100.0" text="Type" />
                            <TableColumn fx:id="transactionAmountColumn" prefWidth="100.0" text="Amount" />
                          </columns>
                        </TableView>
                     </children>
                  </VBox>
               </content>
          </Tab>
        </tabs>
      </TabPane>
   </center>
   <bottom>
      <HBox alignment="CENTER_RIGHT" spacing="10.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
         <children>
            <Label fx:id="statusLabel" text="Ready" HBox.hgrow="ALWAYS" />
         </children>
      </HBox>
   </bottom>
</BorderPane>
