<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.PieChart?>

<VBox xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.smartbank.controller.SessionMonitoringController" 
      spacing="15" styleClass="content-panel">
    
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>
    
    <Label text="Session Monitoring" styleClass="page-title"/>
    
    <TabPane VBox.vgrow="ALWAYS">
        <Tab text="Active Sessions" closable="false">
            <VBox spacing="10">
                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <Label text="Total Active Sessions:" styleClass="info-label"/>
                    <Label fx:id="lblActiveSessionCount" text="0" styleClass="value-label"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="Refresh" onAction="#handleRefresh"/>
                    <Button text="Terminate Selected" onAction="#handleTerminateSelected"/>
                    <Button text="Terminate All" onAction="#handleTerminateAll"/>
                </HBox>
                
                <TableView fx:id="tblActiveSessions" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colSessionId" text="Session ID" prefWidth="180"/>
                        <TableColumn fx:id="colUsername" text="Username" prefWidth="120"/>
                        <TableColumn fx:id="colCreationTime" text="Created" prefWidth="140"/>
                        <TableColumn fx:id="colExpirationTime" text="Expires" prefWidth="140"/>
                        <TableColumn fx:id="colRemainingTime" text="Remaining" prefWidth="100"/>
                        <TableColumn fx:id="colIpAddress" text="IP Address" prefWidth="120"/>
                        <TableColumn fx:id="colActions" text="Actions" prefWidth="100"/>
                    </columns>
                </TableView>
            </VBox>
        </Tab>
        
        <Tab text="Session Activity" closable="false">
            <VBox spacing="10">
                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <ChoiceBox fx:id="choiceActivityFilter" prefWidth="150"/>
                    <TextField fx:id="txtActivitySearch" promptText="Search by username..." HBox.hgrow="ALWAYS"/>
                    <Button text="Search" onAction="#handleSearchActivity"/>
                    <Button text="Clear" onAction="#handleClearActivitySearch"/>
                </HBox>
                
                <TableView fx:id="tblSessionActivity" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colActivityTimestamp" text="Timestamp" prefWidth="140"/>
                        <TableColumn fx:id="colActivityUsername" text="Username" prefWidth="120"/>
                        <TableColumn fx:id="colActivitySessionId" text="Session ID" prefWidth="180"/>
                        <TableColumn fx:id="colActivityType" text="Activity Type" prefWidth="120"/>
                        <TableColumn fx:id="colActivityDetails" text="Details" prefWidth="240"/>
                    </columns>
                </TableView>
            </VBox>
        </Tab>
        
        <Tab text="Statistics" closable="false">
            <HBox spacing="15">
                <VBox spacing="10" HBox.hgrow="ALWAYS">
                    <GridPane hgap="10" vgap="5">
                        <padding>
                            <Insets top="10" right="10" bottom="10" left="10"/>
                        </padding>
                        
                        <Label text="Sessions Created:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <Label fx:id="lblSessionsCreated" text="0" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                        
                        <Label text="Sessions Renewed:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <Label fx:id="lblSessionsRenewed" text="0" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                        
                        <Label text="Sessions Invalidated:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                        <Label fx:id="lblSessionsInvalidated" text="0" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                        
                        <Label text="Sessions Expired:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                        <Label fx:id="lblSessionsExpired" text="0" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
                        
                        <Label text="Active Sessions:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                        <Label fx:id="lblStatsActiveSessions" text="0" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
                        
                        <Label text="Failed Logins:" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                        <Label fx:id="lblFailedLogins" text="0" GridPane.rowIndex="5" GridPane.columnIndex="1"/>
                        
                        <columnConstraints>
                            <ColumnConstraints prefWidth="150"/>
                            <ColumnConstraints prefWidth="50"/>
                        </columnConstraints>
                    </GridPane>
                    
                    <HBox spacing="10" alignment="CENTER">
                        <Button text="Reset Statistics" onAction="#handleResetStatistics"/>
                    </HBox>
                </VBox>
                
                <VBox spacing="10" HBox.hgrow="ALWAYS">
                    <PieChart fx:id="chartSessionTypes" title="Session Activity" 
                              legendVisible="true" labelsVisible="true" VBox.vgrow="ALWAYS"/>
                </VBox>
            </HBox>
        </Tab>
        
        <Tab text="Settings" closable="false">
            <VBox spacing="10">
                <GridPane hgap="15" vgap="10">
                    <padding>
                        <Insets top="10" right="10" bottom="10" left="10"/>
                    </padding>
                    
                    <Label text="Default Session Timeout (minutes):" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtDefaultTimeout" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                    
                    <Label text="Extension Timeout (minutes):" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtExtendTimeout" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                    
                    <Label text="Maximum Session Duration (minutes):" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtMaxTimeout" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                    
                    <Label text="Inactivity Warning (minutes):" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtInactivityWarning" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
                    
                    <Label text="Remember Me Duration (days):" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtRememberMeDays" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
                    
                    <Label text="Auto-Renew Sessions:" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                    <CheckBox fx:id="chkAutoRenew" GridPane.rowIndex="5" GridPane.columnIndex="1"/>
                    
                    <columnConstraints>
                        <ColumnConstraints prefWidth="250"/>
                        <ColumnConstraints prefWidth="150"/>
                    </columnConstraints>
                </GridPane>
                
                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <Button text="Reset to Defaults" onAction="#handleResetDefaults"/>
                    <Button text="Save Settings" onAction="#handleSaveSettings"/>
                </HBox>
            </VBox>
        </Tab>
    </TabPane>
</VBox>