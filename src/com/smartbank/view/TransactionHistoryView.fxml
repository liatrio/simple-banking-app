<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.smartbank.controller.TransactionHistoryController" 
      spacing="10" alignment="TOP_CENTER" VBox.vgrow="ALWAYS" 
      HBox.hgrow="ALWAYS" fillWidth="true">
    
    <padding>
        <Insets top="10" right="10" bottom="10" left="10"/>
    </padding>
    
    <Label text="Transaction History" styleClass="heading" />
    
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Select Account:" />
        <ComboBox fx:id="accountComboBox" onAction="#handleAccountSelection" />
    </HBox>
    
    <TableView fx:id="transactionTable" VBox.vgrow="ALWAYS" HBox.hgrow="ALWAYS">
        <columns>
            <TableColumn text="Date" fx:id="colDate" prefWidth="100" />
            <TableColumn text="Account" fx:id="colAccount" prefWidth="100" />
            <TableColumn text="Type" fx:id="colType" prefWidth="100" />
            <TableColumn text="Amount" fx:id="colAmount" prefWidth="100" />
            <TableColumn text="Description" fx:id="colDescription" prefWidth="150" />
            <TableColumn text="Merchant" fx:id="colMerchant" prefWidth="120" />
            <TableColumn text="Category" fx:id="colCategory" prefWidth="120" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
        <placeholder>
            <Label text="No transactions found for this account" />
        </placeholder>
    </TableView>
</VBox>
