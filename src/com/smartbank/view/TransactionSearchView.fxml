<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.smartbank.controller.TransactionSearchController"
            prefHeight="700.0" prefWidth="1000.0">
    <padding>
        <Insets top="10" right="10" bottom="10" left="10"/>
    </padding>
    
    <top>
        <VBox spacing="10">
            <Label text="Advanced Transaction Search" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
            
            <GridPane hgap="10" vgap="10">
                <columnConstraints>
                    <ColumnConstraints hgrow="SOMETIMES" minWidth="100" prefWidth="100" />
                    <ColumnConstraints hgrow="SOMETIMES" minWidth="200" prefWidth="200" />
                    <ColumnConstraints hgrow="SOMETIMES" minWidth="100" prefWidth="100" />
                    <ColumnConstraints hgrow="SOMETIMES" minWidth="200" prefWidth="200" />
                </columnConstraints>
                
                <!-- Row 0 -->
                <Label text="Account:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                <ComboBox fx:id="accountComboBox" GridPane.columnIndex="1" GridPane.rowIndex="0" 
                          GridPane.hgrow="ALWAYS" maxWidth="Infinity" />
                
                <Label text="Transaction Type:" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                <ComboBox fx:id="typeComboBox" GridPane.columnIndex="3" GridPane.rowIndex="0" 
                          GridPane.hgrow="ALWAYS" maxWidth="Infinity" />
                
                <!-- Row 1 -->
                <Label text="Date Range:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                <HBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="1">
                    <DatePicker fx:id="startDatePicker" promptText="Start Date" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                    <Label text="to" />
                    <DatePicker fx:id="endDatePicker" promptText="End Date" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                </HBox>
                
                <Label text="Amount Range:" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                <HBox spacing="5" GridPane.columnIndex="3" GridPane.rowIndex="1">
                    <TextField fx:id="minAmountField" promptText="Min" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                    <Label text="to" />
                    <TextField fx:id="maxAmountField" promptText="Max" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                </HBox>
                
                <!-- Row 2 -->
                <Label text="Description:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                <TextField fx:id="descriptionField" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                
                <Label text="Merchant:" GridPane.columnIndex="2" GridPane.rowIndex="2" />
                <TextField fx:id="merchantField" GridPane.columnIndex="3" GridPane.rowIndex="2" />
                
                <!-- Row 3 -->
                <Label text="Category:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                <ComboBox fx:id="categoryComboBox" GridPane.columnIndex="1" GridPane.rowIndex="3" 
                          GridPane.hgrow="ALWAYS" maxWidth="Infinity" />
                
                <Label text="Additional Options:" GridPane.columnIndex="2" GridPane.rowIndex="3" />
                <VBox spacing="5" GridPane.columnIndex="3" GridPane.rowIndex="3">
                    <CheckBox fx:id="includeSubcategoriesCheckbox" text="Include subcategories" />
                    <CheckBox fx:id="isRecurringCheckbox" text="Recurring only" />
                    <CheckBox fx:id="isAutoCategorizedCheckbox" text="Auto-categorized only" />
                </VBox>
                
                <!-- Row 4 -->
                <Label text="Sort By:" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                <HBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="4">
                    <ComboBox fx:id="sortByComboBox" promptText="Sort By" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                    <ComboBox fx:id="sortDirectionComboBox" promptText="Direction" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                </HBox>
                
                <Label text="Page Size:" GridPane.columnIndex="2" GridPane.rowIndex="4" />
                <TextField fx:id="pageSizeField" GridPane.columnIndex="3" GridPane.rowIndex="4" />
            </GridPane>
            
            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Button fx:id="clearSearchButton" text="Clear Search" />
                <Button fx:id="saveSearchButton" text="Save Search" />
                <Button text="Search" onAction="#performSearch" defaultButton="true" />
            </HBox>
        </VBox>
    </top>
    
    <center>
        <VBox spacing="10">
            <HBox spacing="20" alignment="CENTER_LEFT">
                <Label fx:id="resultCountLabel" text="No results yet" />
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="timeLabel" text="" />
                <ComboBox fx:id="exportFormatComboBox" prefWidth="100" />
                <Button fx:id="exportButton" text="Export" />
            </HBox>
            
            <TableView fx:id="transactionTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="idColumn" text="ID" prefWidth="60" />
                    <TableColumn fx:id="accountColumn" text="Account" prefWidth="100" />
                    <TableColumn fx:id="typeColumn" text="Type" prefWidth="100" />
                    <TableColumn fx:id="amountColumn" text="Amount" prefWidth="100" />
                    <TableColumn fx:id="dateColumn" text="Date" prefWidth="120" />
                    <TableColumn fx:id="descriptionColumn" text="Description" prefWidth="200" />
                    <TableColumn fx:id="merchantColumn" text="Merchant" prefWidth="150" />
                    <TableColumn fx:id="categoryColumn" text="Category" prefWidth="150" />
                </columns>
            </TableView>
            
            <Pagination fx:id="pagination" maxPageIndicatorCount="10" />
        </VBox>
    </center>
    
    <right>
        <VBox spacing="10" prefWidth="200">
            <padding>
                <Insets left="10"/>
            </padding>
            <Label text="Saved Searches" style="-fx-font-weight: bold;"/>
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
                <VBox fx:id="savedSearchesBox" spacing="5" />
            </ScrollPane>
        </VBox>
    </right>
</BorderPane>